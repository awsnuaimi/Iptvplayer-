package com.example.iptvplayer.ui.adapter

import android.view.LayoutInflater
import android.view.ViewGroup
import android.widget.ImageView
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView
import coil.load
import com.example.iptvplayer.R
import com.example.iptvplayer.data.model.Channel

class ChannelAdapter(
    private var channels: List<Channel>,
    private val onItemClick: (Channel) -> Unit
) : RecyclerView.Adapter<ChannelAdapter.ViewHolder>() {

    inner class ViewHolder(item: android.view.View) : RecyclerView.ViewHolder(item) {
        private val ivLogo: ImageView = item.findViewById(R.id.ivChannelLogo)
        private val tvName: TextView = item.findViewById(R.id.tvChannelName)
        private val tvGroup: TextView = item.findViewById(R.id.tvChannelGroup)

        fun bind(channel: Channel) {
            tvName.text = channel.name
            tvGroup.text = channel.group
            ivLogo.load(channel.logo) {
                placeholder(R.drawable.ic_play_arrow)
                error(R.drawable.ic_play_arrow)
            }
            item.setOnClickListener { onItemClick(channel) }
        }
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context).inflate(R.layout.item_channel, parent, false)
        return ViewHolder(view)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(channels[position])
    }

    override fun getItemCount(): Int = channels.size

    fun updateList(newList: List<Channel>) {
        channels = newList
        notifyDataSetChanged()
    }
}